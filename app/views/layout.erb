<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <% if authorized? %>
      <meta http-equiv="refresh" content="30">
    <% end %>

    <title><%= @title || 'SOLECTRUS :: Ingest' %></title>

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">

    <link rel="stylesheet" href="/dashboard.css">
  </head>

  <body>
    <header class="brand">
      <div class="brand__mark" aria-hidden="true"></div>
      <div class="brand__text">
        <span class="brand__eyebrow">SOLECTRUS</span>
        <span class="brand__title">Ingest</span>
      </div>
      <% if authorized? %>
        <div class="brand__meta">
          <span class="brand__live" title="Live data">Live</span>
          <span class="brand__updated" title="<%= Time.current.strftime('%H:%M:%S') %>">Updated just now</span>
        </div>
      <% end %>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer><%= h build_info %></footer>

    <% if authorized? %>
      <script src="/dashboard.js" defer></script>
    <% end %>
  </body>
</html>
