<div class="grid">
  <section>
    <h2>Incoming</h2>
    <dl class="right">
      <dt>Total</dt>
      <dd><%= number_to_delimited(incoming_total) %></dd>

      <dt>Range <small>(max <%= retention_hours %>h)</small></dt>
      <dd><%= format_duration(incoming_range) %></dd>

      <dt>Throughput</dt>
      <dd><%= number_to_delimited(incoming_throughput) %> /min</dd>
    </dl>
  </section>

  <section>
    <h2>Outgoing</h2>
    <dl class="right">
      <dt>Queued</dt>
      <dd><%= number_to_delimited(outgoing_total) %></dd>

      <dt>Queue age (oldest)</dt>
      <dd><%= format_duration(queue_oldest_age) %></dd>
    </dl>
  </section>

  <section>
    <h2>Cache</h2>
    <dl class="right">
      <dt>Size</dt>
      <dd><%= number_to_delimited(cache_size) %></dd>

      <dt>Range</dt>
      <dd><%= format_duration(cache_range) %></dd>
    </dl>
  </section>

  <section>
    <h2>HousePower Calculation</h2>
    <dl class="right">
      <dt>Count</dt>
      <dd><%= number_to_delimited(calculation_count) %></dd>

      <dt>Rate</dt>
      <dd><%= value_or_dash(calculation_rate) { |r| "#{number_to_delimited(r.round)} /min" } %></dd>

      <dt>Cache hits</dt>
      <dd><%= value_or_dash(calculation_cache_hits) { |v| number_to_percentage(v, precision: 0) } %></dd>

      <dt>Skipped (stale)</dt>
      <dd><%= value_or_dash(calculation_skipped) { |v| number_to_percentage(v, precision: 1) } %></dd>

      <dt>Last success</dt>
      <dd><%= value_or_dash(last_calculation_age) { |a| "#{format_duration(a)} ago" } %></dd>
    </dl>

    <% if calculation_skips_by_sensor.any? %>
      <h2>Skipped by Sensor</h2>
      <dl class="right">
        <% calculation_skips_by_sensor.each do |sensor, count| %>
          <dt class="font-mono"><%= sensor %></dt>
          <dd><%= number_to_delimited(count) %></dd>
        <% end %>
      </dl>
    <% end %>
  </section>

  <section>
    <h2>Responses</h2>
    <dl class="right">
      <% Stats.counters_by(:http_response).sort.each do |key, value| %>
        <dt><%= key.to_s.gsub('http_response_', 'HTTP ') %></dt>
        <dd><%= number_to_delimited(value) %></dd>
      <% end %>

      <dt>Total requests</dt>
      <dd><%= number_to_delimited(Stats.counter(:http_requests)) %></dd>

      <dt>⌀ Time</dt>
      <dd><%= number_to_delimited(response_time) %> ms</dd>
    </dl>
  </section>

  <section>
    <h2>Runtime</h2>
    <dl class="right">
      <dt>CPU usage</dt>
      <dd><%= number_to_percentage(cpu_usage, precision: 1) %></dd>

      <dt>Threads</dt>
      <dd><%= thread_count %></dd>

      <dt>Memory usage</dt>
      <dd><%= number_to_human_size(memory_usage) %></dd>

      <dt>SQLite database</dt>
      <dd><%= number_to_human_size(database_size) %></dd>

      <dt>Disk free</dt>
      <dd><%= number_to_human_size(disk_free) %></dd>
    </dl>

    <h2>Uptime</h2>
    <dl class="right">
      <dt>Container</dt>
      <dd><%= format_duration(container_uptime) %></dd>

      <dt>System</dt>
      <dd><%= format_duration(system_uptime) %></dd>
    </dl>
  </section>
</div>

<section class="section">
  <h2 class="section__label">Measurements &amp; Fields <small>(with throughput)</small></h2>

  <div class="cards">
    <% incoming_measurement_fields_grouped.each do |measurement, groups| %>
      <article class="card">
        <h3 class="card__title"><%= measurement %></h3>
        <ul class="card__list">
          <% groups.each do |group| %>
            <li>
              <span class="font-mono"><%= group[:field] %></span>
              <%= throughput_tag(incoming_throughput_for(group[:count])) %>
            </li>
          <% end %>
        </ul>
      </article>
    <% end %>
  </div>
</section>
