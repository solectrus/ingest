<div class="auth">
  <h2 class="auth__title">Unlock dashboard</h2>
  <p class="auth__hint">Enter the access password to view statistics.</p>

  <form method="post">
    <div class="input-group">
      <input
        name="password"
        placeholder="Password"
        type="password"
        autocomplete="current-password"
        required
        autofocus>

      <button type="submit">Unlock</button>
    </div>

    <% if @error %>
      <p class="error"><%= @error %></p>
    <% end %>
  </form>
</div>
